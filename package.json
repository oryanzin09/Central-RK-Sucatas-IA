{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build:frontend && npm run build:server",
    "build:frontend": "NODE_ENV=production vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/server.js --packages=external",
